    <episode-num system="onscreen">S1 E29</episode-num>
  </programme>
  <programme start="20260318052500 +0000" stop="20260318055000 +0000" channel="Discovery Channel">
    <title lang="it">Come fanno gli animali</title>
    <sub-title lang="it">Cani, uccelli migratori e tigri</sub-title>
    <desc lang="it">Gli esperti rispondono alla domanda se un cane si sente in colpa quando ha fatto qualcosa di sbagliato. Inoltre, rivelano perché le tigri sono arancioni e perché gli uccelli migratori a lunga distanza non si perdono mai.</desc>
    <credits>
      <director>Katie Buckland</director>
